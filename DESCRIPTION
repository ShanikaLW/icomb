Package: icomb
Title: Forecasting Hierarchical Time Series Using Information Combination
Version: 0.1.0
Authors@R: 
    c(person(given = "Shanika", 
             family = "Wickramasuriya", 
             email = "shanika.wickramasuriya@monash.edu", 
             role = c("aut", "cre", "cph")),
      person(given = "Mitchell",
             family = "O'Hara-Wild",
             role = "ctb"),
